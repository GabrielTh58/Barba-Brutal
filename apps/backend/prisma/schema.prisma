generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgres"
}

model Usuario {
  id           String          @id @default(uuid())
  nome         String
  email        String        @unique
  senha        String
  telefone     String?
  barbeiro     Boolean
  agendamentos Agendamento[]
  profissionalId String?          @unique 
  profissional   Profissional? @relation(fields: [profissionalId], references: [id])

  @@map("usuarios")
}

model Profissional {
  id                   String          @id @default(uuid())
  nome                 String        @unique
  descricao            String
  imagemURL            String?
  avaliacao            Float?
  quantidadeAvaliacoes Int?
  agendamentos         Agendamento[]
  usuario              Usuario?

  @@map("profissionais")
}

model Servico {
  id           String          @id @default(uuid())
  nome         String        @unique
  descricao    String
  preco        Float
  qtdeSlots    Int
  imagemURL    String
  agendamentos Agendamento[] @relation("AgendamentoToServico")

  @@map("servicos")
}

model Agendamento {
  id             String          @id @default(uuid())
  data           DateTime
  usuarioId      String
  profissionalId String
  profissional   Profissional @relation(fields: [profissionalId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  servicos       Servico[]    @relation("AgendamentoToServico")

  @@map("agendamentos")
}
