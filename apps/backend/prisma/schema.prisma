generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgres"
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String        @unique
  senha        String
  telefone     String?
  barbeiro     Boolean
  agendamentos Agendamento[]

  @@map("usuarios")
}

model Profissional {
  id                   Int           @id @default(autoincrement())
  nome                 String        @unique
  descricao            String
  imagemURL            String
  avaliacao            Float
  quantidadeAvaliacoes Int
  agendamentos         Agendamento[]

  @@map("profissionais")
}

model Servico {
  id           Int           @id @default(autoincrement())
  nome         String        @unique
  descricao    String
  preco        Float
  qtdeSlots    Int
  imagemURL    String
  agendamentos Agendamento[] @relation("AgendamentoToServico")

  @@map("servicos")
}

model Agendamento {
  id             Int          @id @default(autoincrement())
  data           DateTime
  usuarioId      Int
  profissionalId Int
  profissional   Profissional @relation(fields: [profissionalId], references: [id])
  usuario        Usuario      @relation(fields: [usuarioId], references: [id])
  servicos       Servico[]    @relation("AgendamentoToServico")

  @@map("agendamentos")
}
